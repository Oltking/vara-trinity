type BountyPage = struct {
  bounties: vec Bounty,
};

type Bounty = struct {
  id: u64,
  creator: actor_id,
  description: str,
  metadata_url: str,
  reward: u128,
  status: BountyStatus,
  claimant: opt actor_id,
  proof_url: opt str,
  created_at: u64,
};

type BountyStatus = enum {
  Open,
  Claimed,
  Submitted,
  Approved,
  Cancelled,
};

type Config = struct {
  admin: actor_id,
  fee: u128,
  bounty_count: u64,
};

constructor {
  New : (admin: actor_id, fee: u128);
};

service BountyBoard {
  ApproveBounty : (bounty_id: u64) -> null;
  CancelBounty : (bounty_id: u64) -> null;
  ClaimBounty : (bounty_id: u64) -> null;
  ImportState : (encoded_state: vec u8) -> null;
  PostBounty : (description: str, metadata_url: str) -> u64;
  SetFee : (new_fee: u128) -> null;
  SubmitWork : (bounty_id: u64, proof_url: str) -> null;
  WithdrawFees : () -> null;
  query ExportState : () -> vec u8;
  query GetBountiesByCreator : (creator: actor_id, cursor: opt u64, limit: u32) -> BountyPage;
  query GetBountiesByStatus : (status: BountyStatus, cursor: opt u64, limit: u32) -> BountyPage;
  query GetBounty : (id: u64) -> opt Bounty;
  query GetConfig : () -> Config;

  events {
    BountyPosted: struct { id: u64, creator: actor_id, description: str, reward: u128, fee_paid: u128 };
    BountyClaimed: struct { id: u64, claimant: actor_id };
    WorkSubmitted: struct { id: u64, proof_url: str };
    BountyApproved: struct { id: u64, reward: u128, creator: actor_id, claimant: actor_id };
    BountyCancelled: struct { id: u64, reward_returned: u128 };
    FeeUpdated: struct { old_fee: u128, new_fee: u128 };
    FeesWithdrawn: struct { amount: u128, to: actor_id };
  }
};
